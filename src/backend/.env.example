APP_NAME=xchain-demo
APP_ENV=dev
APP_PORT=8000

API_KEY=
ETH_RPC_URL=https://rpc.ankr.com/eth/${API_KEY}
TARGET_CHAIN=arbitrum
TARGET_CHAIN_RPC_URL=https://rpc.ankr.com/${TARGET_CHAIN}/${API_KEY}
TARGET_CHAIN_EXPLORER_BASE_URL=https://arbiscan.io

ETH_START_BLOCK=24628100
TARGET_CHAIN_START_BLOCK=440372000
ETH_FINALITY_DEPTH=12
TARGET_CHAIN_FINALITY_DEPTH=12

INDEXER_POLL_SECONDS=30
INDEXER_CHUNK_SIZE=2000
STUCK_TIMEOUT_MINUTES=30
MAINTENANCE_ENABLED=true
MAINTENANCE_POLL_SECONDS=21600
MAINTENANCE_REMOVED_RETENTION_DAYS=7
MAINTENANCE_EXECUTED_RETENTION_DAYS=60
MAINTENANCE_FAILED_ARCHIVE_RETENTION_DAYS=60
MAINTENANCE_ARCHIVE_DIR=./archives
MAINTENANCE_VACUUM_INTERVAL_HOURS=168
MAINTENANCE_VACUUM_MIN_DELETED_ROWS=10000

# LayerZero / Wormhole（Ethereum Mainnet Prod 對應事件 topic0）
# 注意：topic0 由事件簽名 Keccak-256 計算，跨 EVM 鏈一致。
LAYERZERO_TOPIC0S=0x1ab700d4ced0c005b164c0f789fd09fcbb0156d4c2041b8a3bfbcd961cd1567f,0x0d87345f3d1c929caba93e1c3821b54ff3512e12b66aa3cfe54b6bcbc17e59b4,0x3cd5e48f9730b129dc7550f0fcea9c767b7be37837cd10e55eb35f734f4bca04,0x7edfa10fe10193301ad8a8bea7e968c7bcabcc64981f368e3aeada40ce26ae2c
WORMHOLE_TOPIC0S=0x6eb224fb001ed210e379b335e35efe88672a8ce935d981a6896b27ffdf52a3b2,0xcaf280c8cfeba144da67230d9b009c8f868a75bac9a528fa0474be1ba317c169
# LayerZero SENT 事件：PacketSent(bytes,bytes,address)
LAYERZERO_SENT_TOPICS=0x1ab700d4ced0c005b164c0f789fd09fcbb0156d4c2041b8a3bfbcd961cd1567f
# LayerZero VERIFIED 事件：PacketVerified((uint32,bytes32,uint64),address,bytes32)
LAYERZERO_VERIFIED_TOPICS=0x0d87345f3d1c929caba93e1c3821b54ff3512e12b66aa3cfe54b6bcbc17e59b4
# LayerZero EXECUTED 事件：PacketDelivered((uint32,bytes32,uint64),address)
LAYERZERO_EXECUTED_TOPICS=0x3cd5e48f9730b129dc7550f0fcea9c767b7be37837cd10e55eb35f734f4bca04
# LayerZero FAILED 事件：LzReceiveAlert(address,address,(uint32,bytes32,uint64),bytes32,uint256,uint256,bytes,bytes,bytes)
LAYERZERO_FAILED_TOPICS=0x7edfa10fe10193301ad8a8bea7e968c7bcabcc64981f368e3aeada40ce26ae2c
# Wormhole SENT 事件（Core）：LogMessagePublished(address,uint64,uint32,bytes,uint8)
WORMHOLE_SENT_TOPICS=0x6eb224fb001ed210e379b335e35efe88672a8ce935d981a6896b27ffdf52a3b2
# Wormhole EXECUTED 事件（Token Bridge）：TransferRedeemed(uint16,bytes32,uint64)
WORMHOLE_EXECUTED_TOPICS=0xcaf280c8cfeba144da67230d9b009c8f868a75bac9a528fa0474be1ba317c169

# 協議合約地址白名單（逗號分隔；僅保留這些地址的 logs）
# 以下示例地址對應 Ethereum <-> Arbitrum 主網；若切換 TARGET_CHAIN，必須同步替換。
LAYERZERO_ETHEREUM_ENDPOINTS=0x1a44076050125825900e736c501f859c50fE728c
LAYERZERO_TARGET_ENDPOINTS=0x1a44076050125825900e736c501f859c50fE728c
WORMHOLE_ETHEREUM_CORE_CONTRACTS=0x98f3c9e6E3fAce36bAAd05FE09d375Ef1464288B
WORMHOLE_TARGET_CORE_CONTRACTS=0xa5f208e072434bC67592E4C49C1B991BA79BCA46
WORMHOLE_ETHEREUM_TOKEN_BRIDGES=0x3ee18B2214AFF97000D974cf647E7C347E8fa585
WORMHOLE_TARGET_TOKEN_BRIDGES=0x0b2402144bb366A632D14B83F244D2E0E21bd39c

# 方向校驗映射（Ethereum + TARGET_CHAIN）
LAYERZERO_ETHEREUM_EID=30101
LAYERZERO_TARGET_EID=30110
WORMHOLE_ETHEREUM_CHAIN_ID=2
WORMHOLE_TARGET_CHAIN_ID=23

DB_PATH=sqlite:///./xchain_demo.db
